# NPM Configuration for Dependency Stability
# Last updated: 2026-03-15

# Enforce exact versions for critical dependencies to prevent unexpected upgrades
save-exact=false

# Use lockfile versioning for reproducible builds across environments
save-prefix=

# Audit security on install
audit=true

# Fail on audit vulnerabilities (adjust if blocking CI/CD)
audit-level=moderate

# Require matching peer dependencies
strict-peer-dependencies=true

# Cache policy - keep node_modules consistent
package-lock=true

# Use npm 10+ feature: workspaces consistency
workspaces-strict=true
