BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//LeadFlowPro//Dependency Management//EN
CALSCALE:GREGORIAN
METHOD:PUBLISH
NAME:LeadFlowPro Dependency Management
DESCRIPTION:Recurring reminders for dependency updates and security audits

BEGIN:VEVENT
UID:leadflow-monthly-audit-2026@leadflow-pro.local
DTSTART:20260404T094500Z
DTEND:20260404T100000Z
RRULE:FREQ=MONTHLY;BYDAY=1FR;BYHOUR=9;BYMINUTE=45
SUMMARY:LeadFlowPro: Monthly Dependency Audit
DESCRIPTION:Run: npm run audit:dependencies\n\nCheck for:\n- Security vulnerabilities\n- Outdated Tier 4 packages\n- Version mismatches\n\nUpdate DEPENDENCY_UPDATES.md with findings
LOCATION:LeadFlowPro Project
PRIORITY:3
STATUS:CONFIRMED
CATEGORIES:Development,DevOps,Security
END:VEVENT

