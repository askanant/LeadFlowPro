generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Core Tenant / Company ────────────────────────────────────────────────────

model Company {
  id             String  @id @default(uuid())
  tenantId       String  @unique @map("tenant_id")
  name           String  @db.VarChar(255)
  industry       String? @db.VarChar(100)
  businessType   String? @map("business_type") @db.VarChar(100)
  description    String? @db.Text
  targetGeo      Json?   @map("target_geo")      // { country, states[], cities[] }
  leadCriteria   Json?   @map("lead_criteria")   // AI-readable quality rules
  pricingDetails Json?   @map("pricing_details")
  offerDetails   String? @map("offer_details") @db.Text
  status         String  @default("active") @db.VarChar(20)
  settings       Json    @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                 User[]
  adPlatformCredentials AdPlatformCredential[]
  campaigns             Campaign[]
  leads                 Lead[]
  phoneNumbers          PhoneNumber[]
  callLogs              CallLog[]
  whatsappTemplates     WhatsappTemplate[]
  aiSuggestions         AiSuggestion[]
  subscription          Subscription?

  @@map("companies")
}

model AdPlatformCredential {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  platform       String    @db.VarChar(50) // 'meta', 'google', 'linkedin', 'microsoft', 'taboola'
  accountId      String?   @map("account_id") @db.VarChar(100)
  accessToken    String?   @map("access_token") @db.Text // encrypted at rest
  refreshToken   String?   @map("refresh_token") @db.Text // encrypted at rest
  appId          String?   @map("app_id") @db.VarChar(100)
  appSecret      String?   @map("app_secret") @db.Text // encrypted at rest
  extraConfig    Json?     @map("extra_config")
  tokenExpiresAt DateTime? @map("token_expires_at")
  isValid        Boolean   @default(true) @map("is_valid")
  createdAt      DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [tenantId], references: [tenantId])

  @@unique([tenantId, platform])
  @@map("ad_platform_credentials")
}

// ─── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  name               String    @db.VarChar(255)
  platform           String    @db.VarChar(50)
  platformCampaignId String?   @map("platform_campaign_id") @db.VarChar(100)
  status             String    @default("draft") @db.VarChar(30)
  dailyBudget        Decimal?  @map("daily_budget") @db.Decimal(12, 2)
  totalBudget        Decimal?  @map("total_budget") @db.Decimal(12, 2)
  leadTargetDaily    Int?      @map("lead_target_daily")
  leadTargets        Json?     @map("lead_targets")       // { monday: 10, tuesday: 8 }
  targetingConfig    Json?     @map("targeting_config")   // AI-generated
  startDate          DateTime? @map("start_date") @db.Date
  endDate            DateTime? @map("end_date") @db.Date
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  company         Company          @relation(fields: [tenantId], references: [tenantId])
  leads           Lead[]
  campaignMetrics CampaignMetric[]
  aiSuggestions   AiSuggestion[]

  @@map("campaigns")
}

// ─── Leads ────────────────────────────────────────────────────────────────────

model Lead {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  campaignId     String?  @map("campaign_id")
  platform       String?  @db.VarChar(50)
  platformLeadId String?  @map("platform_lead_id") @db.VarChar(200)
  firstName      String?  @map("first_name") @db.VarChar(100)
  lastName       String?  @map("last_name") @db.VarChar(100)
  email          String?  @db.VarChar(255)
  phone          String?  @db.VarChar(30)
  city           String?  @db.VarChar(100)
  state          String?  @db.VarChar(100)
  customFields   Json?    @map("custom_fields")
  qualityScore   Int?     @map("quality_score") @db.SmallInt // 0-100
  status         String   @default("new") @db.VarChar(30)
  sourceUrl      String?  @map("source_url") @db.Text
  ipAddress      String?  @map("ip_address")
  receivedAt     DateTime @default(now()) @map("received_at")
  createdAt      DateTime @default(now()) @map("created_at")

  company         Company         @relation(fields: [tenantId], references: [tenantId])
  campaign        Campaign?       @relation(fields: [campaignId], references: [id])
  deliveries      LeadDelivery[]
  callLogs        CallLog[]
  leadCallMatches LeadCallMatch[]

  @@unique([tenantId, platform, platformLeadId])
  @@index([tenantId])
  @@index([phone])
  @@map("leads")
}

model LeadDelivery {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  leadId      String    @map("lead_id")
  channel     String?   @db.VarChar(30) // 'whatsapp', 'webhook', 'email'
  status      String?   @db.VarChar(30) // 'pending', 'delivered', 'failed'
  deliveredAt DateTime? @map("delivered_at")
  deliveryLog Json?     @map("delivery_log") // full API response/receipt
  retryCount  Int       @default(0) @map("retry_count") @db.SmallInt
  createdAt   DateTime  @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id])

  @@map("lead_deliveries")
}

// ─── Telephony ────────────────────────────────────────────────────────────────

model PhoneNumber {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  number      String   @unique @db.VarChar(20)
  provider    String?  @db.VarChar(30) // 'twilio', 'plivo'
  providerSid String?  @map("provider_sid") @db.VarChar(100)
  routingType String?  @map("routing_type") @db.VarChar(30) // 'forward', 'ivr', 'round_robin'
  forwardTo   String?  @map("forward_to") @db.VarChar(20)
  isActive    Boolean  @default(true) @map("is_active")
  purchasedAt DateTime @default(now()) @map("purchased_at")

  company  Company   @relation(fields: [tenantId], references: [tenantId])
  callLogs CallLog[]

  @@map("phone_numbers")
}

model CallLog {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  phoneNumberId   String?   @map("phone_number_id")
  leadId          String?   @map("lead_id")
  callSid         String?   @unique @map("call_sid") @db.VarChar(100)
  fromNumber      String?   @map("from_number") @db.VarChar(20)
  toNumber        String?   @map("to_number") @db.VarChar(20)
  direction       String?   @db.VarChar(10) // 'inbound'
  status          String?   @db.VarChar(30) // 'completed', 'no-answer', 'busy', 'failed'
  durationSeconds Int?      @map("duration_seconds")
  recordingUrl    String?   @map("recording_url") @db.Text // S3 presigned URL
  recordingS3Key  String?   @map("recording_s3_key") @db.Text
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  company         Company         @relation(fields: [tenantId], references: [tenantId])
  phoneNumber     PhoneNumber?    @relation(fields: [phoneNumberId], references: [id])
  lead            Lead?           @relation(fields: [leadId], references: [id])
  leadCallMatches LeadCallMatch[]

  @@index([tenantId])
  @@index([leadId])
  @@map("call_logs")
}

model LeadCallMatch {
  id         String   @id @default(uuid())
  leadId     String   @map("lead_id")
  callLogId  String   @map("call_log_id")
  confidence Decimal? @db.Decimal(3, 2) // 0.00 - 1.00
  createdAt  DateTime @default(now()) @map("created_at")

  lead    Lead    @relation(fields: [leadId], references: [id])
  callLog CallLog @relation(fields: [callLogId], references: [id])

  @@unique([leadId, callLogId])
  @@map("lead_call_matches")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  email        String    @unique @db.VarChar(255)
  passwordHash String?   @map("password_hash") @db.Text
  firstName    String?   @map("first_name") @db.VarChar(100)
  lastName     String?   @map("last_name") @db.VarChar(100)
  role         String    @default("viewer") @db.VarChar(30) // 'super_admin', 'company_admin', 'viewer'
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company   Company    @relation(fields: [tenantId], references: [tenantId])
  auditLogs AuditLog[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(100)
  resourceId String?  @map("resource_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@map("audit_logs")
}

// ─── Analytics ────────────────────────────────────────────────────────────────

model CampaignMetric {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  campaignId  String   @map("campaign_id")
  date        DateTime @db.Date
  spend       Decimal? @db.Decimal(12, 2)
  impressions Int?
  clicks      Int?
  leadsCount  Int?     @map("leads_count")
  cpl         Decimal? @db.Decimal(12, 2) // cost per lead
  createdAt   DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, date])
  @@map("campaign_metrics")
}

// ─── WhatsApp & AI ────────────────────────────────────────────────────────────

model WhatsappTemplate {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  name       String   @db.VarChar(100)
  content    String   @db.Text
  status     String   @default("pending") @db.VarChar(30) // 'pending', 'approved', 'rejected'
  templateId String?  @map("template_id") @db.VarChar(100) // Meta template ID
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [tenantId], references: [tenantId])

  @@map("whatsapp_templates")
}

model AiSuggestion {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  campaignId String?  @map("campaign_id")
  type       String   @db.VarChar(50) // 'targeting', 'budget', 'creative'
  suggestion Json
  confidence Int?     @db.SmallInt // 0-100
  applied    Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  company  Company   @relation(fields: [tenantId], references: [tenantId])
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@map("ai_suggestions")
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model Subscription {
  id                    String    @id @default(uuid())
  tenantId              String    @unique @map("tenant_id")
  plan                  String    @default("starter") @db.VarChar(50)
  stripeCustomerId      String?   @map("stripe_customer_id") @db.VarChar(100)
  stripeSubscriptionId  String?   @map("stripe_subscription_id") @db.VarChar(100)
  status                String    @default("active") @db.VarChar(30) // 'active', 'past_due', 'canceled', 'paused'
  currentPeriodStart    DateTime? @map("current_period_start")
  currentPeriodEnd      DateTime? @map("current_period_end")
  cancelAtPeriodEnd     Boolean   @default(false) @map("cancel_at_period_end")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [tenantId], references: [tenantId])

  @@map("subscriptions")
}
