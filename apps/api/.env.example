# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ─── Database & Cache ──────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/leadflow_dev?sslmode=require

# Redis for caching and job queues
REDIS_URL=redis://localhost:6379

# ─── Authentication & Security (CRITICAL: Store in secure vault, never in repo) ─
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64_character_cryptographically_random_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Platform Integrations ────────────────────────────────────────────────────
# Meta/Facebook
META_WEBHOOK_VERIFY_TOKEN=your_meta_webhook_token
META_APP_SECRET=your_meta_app_secret

# WhatsApp (Meta)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_SYSTEM_USER_TOKEN=your_system_user_token

# OpenAI API
OPENAI_API_KEY=sk-your_openai_api_key

# AWS S3
AWS_REGION=us-east-1
S3_BUCKET_RECORDINGS=your_s3_bucket_name

# Twilio (for phone calls)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Stripe (payment processing)
STRIPE_SECRET_KEY=sk_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─── Email & Notifications ────────────────────────────────────────────────────
# Email service configuration (add as needed)
MAIL_FROM=noreply@leadflowpro.com

# ─── Error Monitoring (Optional) ──────────────────────────────────────────────
# Sentry for error tracking and monitoring
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# ─── Infrastructure Encryption (Phase 2) ──────────────────────────────────────
# AWS KMS key for credential encryption (production only)
KMS_KEY_ID=arn:aws:kms:region:account:key/key-id

# ─── Development-Only Settings ────────────────────────────────────────────────
# Environment-specific features
TELEPHONY_PROVIDER=exotel  # or 'twilio'
ENABLE_MOCK_WEBHOOKS=false

# NOTE: Dev admin credentials should NEVER be committed!
# Set these via environment variables only during local development:
# export DEV_SUPER_ADMIN_EMAIL="your-email@example.com"
# export DEV_SUPER_ADMIN_PASSWORD="secure-password"
# export DEV_SUPER_ADMIN_TENANT_ID="dev-tenant-local"
