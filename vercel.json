{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next-build",
      "config": {
        "zeroConfig": true
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "@leadflow_api_url"
  },
  "buildCommand": "npm run build --workspace @leadflow/web",
  "outputDirectory": "apps/web/dist"
}
