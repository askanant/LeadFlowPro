# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://leadflow:leadflow_dev@localhost:5432/leadflow_dev"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Meta / Facebook Ads ──────────────────────────────────────────────────────
META_APP_ID=""
META_APP_SECRET=""
META_WEBHOOK_VERIFY_TOKEN="your-custom-verify-token"

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# ─── WhatsApp Business (Meta) ─────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_SYSTEM_USER_TOKEN=""

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── AWS (Phase 2 - leave blank for local dev) ────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_RECORDINGS=""

# AWS KMS for credential encryption (production only)
KMS_KEY_ID=""

# ─── Security Configuration ───────────────────────────────────────────────────

# Monitoring & Error Tracking (Optional)
SENTRY_DSN=
DATADOG_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
AUTH_RATE_LIMIT_MAX=5
API_RATE_LIMIT_MAX=100

# Request Handling
REQUEST_TIMEOUT_MS=30000
REQUEST_MAX_SIZE=1mb

# JWT & Token Security
JWT_SECRET=your-secret-key-min-32-chars-required
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_MAX_AGE=604800

# HTTPS & CORS
FRONTEND_URL=https://yourdomain.com
ENFORCE_HTTPS=true

# Logging
LOG_LEVEL=info
ENABLE_AUDIT_LOGS=true

# External Services (Optional)
SENTRY_DSN=
DATADOG_API_KEY=

# ─── Development: Auto-Create Super Admin ─────────────────────────────────────
# Set these ONLY in local .env (never in production)
# Leave empty or undefined in production

DEV_SUPER_ADMIN_EMAIL=anantshukla@live.com
DEV_SUPER_ADMIN_PASSWORD=Admin@$1234!
DEV_SUPER_ADMIN_TENANT_ID=dev-tenant-local
